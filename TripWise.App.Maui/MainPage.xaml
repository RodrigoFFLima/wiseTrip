<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="TripWise.App.MainPage"
             BackgroundColor="#F7F7F9">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="18">

            <VerticalStackLayout Spacing="4">
                <Label Text="TripWise"
                       FontSize="32"
                       FontAttributes="Bold"
                       TextColor="#111827" />

                <Label Text="Estimate fuel, tolls and total trip cost"
                       FontSize="14"
                       TextColor="#6B7280" />
            </VerticalStackLayout>

            <Frame Padding="16"
                   CornerRadius="16"
                   HasShadow="False"
                   BorderColor="#E5E7EB"
                   BackgroundColor="White">

                <VerticalStackLayout Spacing="14">

                    <Label Text="Distance"
                           FontSize="14"
                           FontAttributes="Bold"
                           TextColor="#374151" />

                    <Entry x:Name="DistanceEntry"
                           Placeholder="Enter distance in km"
                           Keyboard="Numeric"
                           ClearButtonVisibility="WhileEditing"
                           BackgroundColor="#F9FAFB"
                           TextColor="#111827"
                           PlaceholderColor="#9CA3AF" />

                    <Label x:Name="ErrorLabel"
                           TextColor="#DC2626"
                           FontSize="13"
                           IsVisible="False" />

                    <Button x:Name="CalculateButton"
                            Text="Calculate trip"
                            Clicked="OnCalculateClicked"
                            BackgroundColor="#4F46E5"
                            TextColor="White"
                            CornerRadius="12"
                            HeightRequest="52" />

                    <ActivityIndicator x:Name="LoadingIndicator"
                                       IsRunning="False"
                                       IsVisible="False"
                                       Color="#4F46E5" />
                </VerticalStackLayout>
            </Frame>

            <Frame x:Name="ResultCard"
                   Padding="18"
                   CornerRadius="16"
                   HasShadow="False"
                   BorderColor="#E5E7EB"
                   BackgroundColor="White"
                   IsVisible="False">

                <VerticalStackLayout Spacing="12">

                    <Label Text="Result"
                           FontAttributes="Bold"
                           FontSize="20"
                           TextColor="#111827" />

                    <BoxView HeightRequest="1"
                             Color="#E5E7EB" />

                    <Grid ColumnDefinitions="*,Auto"
                          RowDefinitions="Auto,Auto,Auto,Auto"
                          RowSpacing="10">

                        <Label Text="Distance"
                               Grid.Row="0" Grid.Column="0"
                               TextColor="#6B7280" />
                        <Label x:Name="DistanceLabel"
                               Grid.Row="0" Grid.Column="1"
                               TextColor="#111827" />

                        <Label Text="Fuel"
                               Grid.Row="1" Grid.Column="0"
                               TextColor="#6B7280" />
                        <Label x:Name="FuelLabel"
                               Grid.Row="1" Grid.Column="1"
                               TextColor="#111827" />

                        <Label Text="Tolls"
                               Grid.Row="2" Grid.Column="0"
                               TextColor="#6B7280" />
                        <Label x:Name="TollLabel"
                               Grid.Row="2" Grid.Column="1"
                               TextColor="#111827" />

                        <Label Text="Total"
                               Grid.Row="3" Grid.Column="0"
                               FontAttributes="Bold"
                               TextColor="#4F46E5" />
                        <Label x:Name="TotalLabel"
                               Grid.Row="3" Grid.Column="1"
                               FontAttributes="Bold"
                               TextColor="#4F46E5" />
                    </Grid>
                </VerticalStackLayout>
            </Frame>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>